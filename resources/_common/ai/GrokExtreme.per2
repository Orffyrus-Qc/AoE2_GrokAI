;==============================================================================
; GrokExtreme — Phase 2 loader (not active until you switch to it)
; Full Extreme AI (Promisory) + adaptive layer on top.
; To use: copy to game's drs folder OR reference from a mod override.
;==============================================================================

(load "Promisory\defaultConstants")
(load "Promisory\finalingConstants")
(load "Promisory\customConstants")
#load-if-not-defined BATTLE-ROYALE
(load "Promisory\init")
