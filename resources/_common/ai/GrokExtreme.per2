(load "Promisory\dawn")
(load "Promisory\gatherers")
(load "Promisory\scoutcontrol")
(load "Promisory\tsa")
(load "Promisory\watercontrol")
(load "Promisory\general")
(load "Promisory\orb")
#load-if-not-defined DIFFICULTY-EASIEST
#load-if-not-defined DIFFICULTY-EASY
#load-if-not-defined DIFFICULTY-MODERATE
#load-if-not-defined INFINITE-RESOURCES-START
(load "Promisory\boarhunting")
#end-if
#end-if
#end-if
#end-if
(load "Promisory\researches")
(load "Promisory\interaction")
(load "Promisory\buildings")
(load "Promisory\units")
(load "Promisory\trade")
