; ======================== MAINTAIN: REPAIR DAMAGED WALLS/GATES ========================
(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-seg == stronghold-seg-wall-south)
=>
	(up-copy-point saved-point-x point4-x)
	(up-full-reset-search)
	(up-set-target-point saved-point-x)
	(up-find-local c: wall-class c: 24)
	(up-find-local c: gate-class c: 12)
	(up-filter-distance c: -1 c: stronghold-repair-radius)
	(up-remove-objects search-local object-data-hitpoints g:>= stronghold-wall-hp-full)
	(up-get-search-state local-total))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain-castle)
