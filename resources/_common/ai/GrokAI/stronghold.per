(defrule
	(up-compare-goal mem-stronghold-active == 1)
(or	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain-castle))
	(up-compare-goal mem-stronghold-seg == stronghold-seg-gate-access)
	(up-compare-goal mem-compound-side-len g:< wall-gate-min-tiles)
=>
	(set-goal mem-stronghold-seg stronghold-seg-done))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
(or	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain-castle))
(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-seg >= stronghold-seg-done)
=>
	(up-modify-goal mem-stronghold-index c:+ 1)
	(set-goal mem-stronghold-seg stronghold-seg-setup))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain-castle)
	(up-compare-goal mem-stronghold-seg >= stronghold-seg-done)
=>
	(up-modify-goal mem-stronghold-index c:+ 1)
	(set-goal mem-stronghold-seg stronghold-seg-setup))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-seg >= stronghold-seg-done)
	(up-compare-goal mem-stronghold-index g:>= mem-stronghold-tc-count)
	(current-age >= castle-age)
	(up-compare-goal mem-stronghold-castle-count >= 1)
=>
	(set-goal mem-stronghold-mode stronghold-mode-maintain-castle)
	(set-goal mem-stronghold-index 0)
	(set-goal mem-stronghold-seg stronghold-seg-setup))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain)
	(up-compare-goal mem-stronghold-seg >= stronghold-seg-done)
	(up-compare-goal mem-stronghold-index g:>= mem-stronghold-tc-count)
=>
	(set-goal mem-stronghold-active 0)
	(set-goal mem-stronghold-mode 0)
	(set-goal mem-stronghold-seg 0)
	(set-goal mem-stronghold-index 0))

(defrule
	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-stronghold-mode == stronghold-mode-maintain-castle)
	(up-compare-goal mem-stronghold-seg >= stronghold-seg-done)
	(up-compare-goal mem-stronghold-index g:>= mem-stronghold-castle-count)
=>
	(set-goal mem-stronghold-active 0)
	(set-goal mem-stronghold-mode 0)
	(set-goal mem-stronghold-seg 0)
	(set-goal mem-stronghold-index 0))

; ======================== ABORT ON ISLAND ========================
(defrule
	(goal inseln yes)
	(up-compare-goal mem-stronghold-active == 1)
=>
	(set-goal mem-stronghold-active 0)
	(set-goal mem-stronghold-mode 0)
	(set-goal mem-stronghold-seg 0))