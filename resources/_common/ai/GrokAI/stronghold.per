	(up-compare-goal mem-stronghold-seg == stronghold-seg-wall-south)
	(up-compare-goal local-total > 0)
	(up-set-target-object search-local c: 0)
=>
	(up-get-object-data object-data-id temporary-goal)
	(up-full-reset-search)
	(up-set-target-point saved-point-x)
	(up-filter-distance c: -1 c: stronghold-repair-radius)
	(up-find-local c: villager g: mem-build-repair-vills)
	(up-remove-objects search-local object-data-order == orderid-repair)
	(up-add-object-by-id search-remote g: temporary-goal)
	(up-target-objects 0 action-default -1 -1))

