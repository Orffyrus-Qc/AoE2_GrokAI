; ======================== CHOKE WALL LINE (SITES 1-2) ========================
(defrule
	(up-compare-goal mem-wall-phase == wall-phase-build)
	(up-compare-goal mem-wall-site >= wall-site-choke-main)
	(up-compare-goal mem-wall-segments == wall-choke-seg-left)
	(wood-amount >= wall-segment-wood)
	(up-pending-objects c: palisade-wall < wall-pending-max)
	(up-can-build-line point-x saved-point-x c: palisade-wall)
=>
	(up-build-line point-x saved-point-x c: palisade-wall)
	(up-assign-builders c: wall-class c: 1)
	(set-goal mem-wall-segments wall-choke-seg-right))

(defrule
	(up-compare-goal mem-wall-phase == wall-phase-build)
	(up-compare-goal mem-wall-site >= wall-site-choke-main)
	(up-compare-goal mem-wall-segments == wall-choke-seg-left)
	(up-compare-goal mem-wall-stuck >= wall-gate-retry-max)
=>
	(set-goal mem-wall-segments wall-choke-seg-right))

(defrule
	(up-compare-goal mem-wall-phase == wall-phase-build)
	(up-compare-goal mem-wall-site >= wall-site-choke-main)
	(up-compare-goal mem-wall-segments == wall-choke-seg-right)
	(wood-amount >= wall-segment-wood)
	(up-pending-objects c: palisade-wall < wall-pending-max)
	(up-can-build-line saved-point-x point2-x c: palisade-wall)
=>
	(up-build-line saved-point-x point2-x c: palisade-wall)
	(up-assign-builders c: wall-class c: 1)
