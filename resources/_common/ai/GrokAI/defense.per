	(up-compare-goal mem-wall-site >= wall-site-choke-main)
	(up-compare-goal mem-wall-segments == wall-choke-seg-right)
	(up-compare-goal mem-wall-stuck >= wall-gate-retry-max)
=>
	(set-goal mem-wall-segments wall-choke-seg-done))

(defrule
	(up-compare-goal mem-wall-phase == wall-phase-build)
	(up-compare-goal mem-wall-site >= wall-site-choke-main)
	(up-compare-goal mem-wall-segments >= wall-choke-seg-left)
	(up-compare-goal mem-wall-stuck < wall-gate-retry-max)
(or	(up-point-contains saved-point-x c: tree-class)
(or	(up-point-contains point-x c: tree-class)
	(up-point-contains point2-x c: tree-class)))
=>
	(up-modify-goal mem-wall-stuck c:+ 1)
	(up-lerp-tiles saved-point-x position-self-x c: 1))