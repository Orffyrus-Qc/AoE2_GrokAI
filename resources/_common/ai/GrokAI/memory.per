;==============================================================================
; GrokAI - In-match memory initialization and rolling trackers
;==============================================================================

(defrule
	(true)
=>
	(set-goal mem-detected-opening opening-unknown)
	(set-goal mem-enemy-archer-peak 0)
	(set-goal mem-enemy-cav-peak 0)
	(set-goal mem-enemy-infantry-peak 0)
	(set-goal mem-attack-events 0)
	(set-goal mem-aggression-score 0)
	(set-goal mem-last-scout-tick 0)
	(set-goal mem-adapt-mode adapt-balanced)
	(set-goal mem-rally-army 0)
	(disable-self))

