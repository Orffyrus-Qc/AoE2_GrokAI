	(true)
=>
	(set-goal mem-wall-active 0)
	(set-goal mem-wall-phase wall-phase-idle)
	(set-goal mem-wall-segments 0)
	(set-goal mem-wall-stuck 0)
	(set-goal mem-wall-dir wall-side-east)
	(set-goal mem-wall-site wall-site-tc)
	(set-goal mem-fort-wave 0)
	(set-goal mem-wall-tier wall-tier-palisade)
	(set-goal mem-wall-gate-type wall-gate-type0)
	(set-goal mem-stronghold-active 0)
	(set-goal mem-stronghold-mode 0)
	(set-goal mem-stronghold-index 0)
	(set-goal mem-stronghold-seg 0)
	(set-goal mem-stronghold-gate-type wall-gate-type0)
	(set-goal mem-stronghold-next-maintain 0)
	(set-goal mem-stronghold-tc-done 0)
	(set-goal mem-stronghold-castle-done 0)
	(set-goal mem-stronghold-tc-count 0)
	(set-goal mem-stronghold-castle-count 0)
	(disable-self))

