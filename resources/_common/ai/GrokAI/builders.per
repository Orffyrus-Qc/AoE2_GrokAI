	(up-compare-goal mem-build-structure-count < 140)
=>
	(set-goal mem-build-tower-target 13))

(defrule
	(up-compare-goal mem-build-structure-count >= 120)
	(up-compare-goal mem-build-structure-count < 130)
=>
	(set-goal mem-build-tower-target 12))

(defrule
	(up-compare-goal mem-build-structure-count >= 110)
	(up-compare-goal mem-build-structure-count < 120)
=>
	(set-goal mem-build-tower-target 11))

(defrule
	(up-compare-goal mem-build-structure-count >= 100)
	(up-compare-goal mem-build-structure-count < 110)
=>
	(set-goal mem-build-tower-target 10))

(defrule
	(up-compare-goal mem-build-structure-count >= 90)
	(up-compare-goal mem-build-structure-count < 100)
=>
	(set-goal mem-build-tower-target 9))

(defrule
	(up-compare-goal mem-build-structure-count >= 80)
	(up-compare-goal mem-build-structure-count < 90)
=>
	(set-goal mem-build-tower-target 8))

(defrule
	(up-compare-goal mem-build-structure-count >= 70)
	(up-compare-goal mem-build-structure-count < 80)
=>
	(set-goal mem-build-tower-target 7))

(defrule
	(up-compare-goal mem-build-structure-count >= 60)
	(up-compare-goal mem-build-structure-count < 70)
=>
	(set-goal mem-build-tower-target 6))

(defrule
	(up-compare-goal mem-build-structure-count >= 50)
	(up-compare-goal mem-build-structure-count < 60)
=>
	(set-goal mem-build-tower-target 5))

(defrule
	(up-compare-goal mem-build-structure-count >= 40)
	(up-compare-goal mem-build-structure-count < 50)
=>
	(set-goal mem-build-tower-target 4))

(defrule
	(up-compare-goal mem-build-structure-count >= 30)
	(up-compare-goal mem-build-structure-count < 40)
=>
	(set-goal mem-build-tower-target 3))

(defrule
	(up-compare-goal mem-build-structure-count >= 20)
	(up-compare-goal mem-build-structure-count < 30)
=>
	(set-goal mem-build-tower-target 2))

(defrule
	(up-compare-goal mem-build-structure-count >= 10)
	(up-compare-goal mem-build-structure-count < 20)
=>
	(set-goal mem-build-tower-target 1))

(defrule
	(up-compare-goal mem-build-structure-count < 10)
=>
	(set-goal mem-build-tower-target 0))

(defrule
	(up-compare-goal mem-build-tower-target g:> fort-tower-cap)
=>
	(set-goal mem-build-tower-target fort-tower-cap))

; ======================== RAMP CAPS + POOL OVER TIME ========================
(defrule
	(current-age >= feudal-age)
	(game-time >= mem-build-next-ramp)
=>
	(up-modify-goal mem-build-next-ramp g:= game-time)
	(up-modify-goal mem-build-next-ramp c:+ build-ramp-interval)
	(up-modify-goal mem-build-gate-cap c:+ 0)
	(up-modify-goal mem-build-wall-cap c:+ 2)
	(up-modify-goal mem-build-pool-size c:+ 0))

(defrule
	(up-compare-goal mem-build-gate-cap g:> fort-gate-cap-max)
=>
	(set-goal mem-build-gate-cap fort-gate-cap-max))

(defrule
	(up-compare-goal mem-build-wall-cap g:> fort-wall-cap-max)
=>
	(set-goal mem-build-wall-cap fort-wall-cap-max))

(defrule
	(up-compare-goal mem-build-pool-size g:> build-pool-max)
=>
	(set-goal mem-build-pool-size build-pool-max))

; ======================== SCALE WORKER TARGETS BY AGE + STRUCTURES ========================
(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-pool-size < build-pool-feudal)
=>
	(set-goal mem-build-pool-size build-pool-feudal))

(defrule
	(current-age >= castle-age)
	(up-compare-goal mem-build-pool-size < build-pool-castle)
=>
	(set-goal mem-build-pool-size build-pool-castle))

(defrule
	(current-age >= imperial-age)
	(up-compare-goal mem-build-pool-size < build-pool-imp)
=>
	(set-goal mem-build-pool-size build-pool-imp))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-stronghold-tc-count >= 3)
	(up-compare-goal mem-build-pool-size g:< build-pool-max)
=>
	(up-modify-goal mem-build-pool-size c:+ 1))

; Per-role targets derived from pool
(defrule
	(current-age >= feudal-age)
=>
	(up-modify-goal mem-build-wall-vills g:= mem-build-pool-size)
	(up-modify-goal mem-build-gate-vills g:= mem-build-pool-size)
	(up-modify-goal mem-build-tower-vills g:= mem-build-pool-size)
	(up-modify-goal mem-build-struct-vills g:= mem-build-pool-size)
	(up-modify-goal mem-build-repair-vills g:= mem-build-pool-size)
	(up-modify-goal mem-build-raid-vills g:= mem-build-pool-size))

(defrule
	(up-compare-goal mem-build-wall-vills g:> build-wall-vills-max)
=>
	(set-goal mem-build-wall-vills build-wall-vills-max))

(defrule
	(up-compare-goal mem-build-gate-vills g:> build-gate-vills-max)
=>
	(set-goal mem-build-gate-vills build-gate-vills-max))

(defrule
	(up-compare-goal mem-build-tower-vills g:> build-tower-vills-max)
=>
	(set-goal mem-build-tower-vills build-tower-vills-max))

(defrule
	(up-compare-goal mem-build-struct-vills g:> build-struct-vills-max)
=>
	(set-goal mem-build-struct-vills build-struct-vills-max))

(defrule
	(up-compare-goal mem-build-repair-vills g:> build-repair-vills-max)
=>
	(set-goal mem-build-repair-vills build-repair-vills-max))

(defrule
	(up-compare-goal mem-build-raid-vills g:> build-raid-vills-max)
=>
	(set-goal mem-build-raid-vills build-raid-vills-max))

(defrule
	(goal underattack yes)
	(up-compare-goal mem-build-repair-vills g:< build-repair-vills-max)
=>
	(up-modify-goal mem-build-repair-vills c:+ 3))

; Minimums so fortify/stronghold always get help
(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-wall-vills < 3)
=>
	(set-goal mem-build-wall-vills 3))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-gate-vills < 3)
=>
	(set-goal mem-build-gate-vills 3))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-tower-vills < 3)
=>
	(set-goal mem-build-tower-vills 3))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-fortify-ready != 1)
(or	(up-compare-goal mem-wall-active == 1)
(or	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-tower-def-active == 1)))
	(up-compare-goal mem-build-wall-vills g:< build-wall-vills-max)
=>
	(up-modify-goal mem-build-wall-vills c:+ 2))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-fortify-ready != 1)
(or	(up-compare-goal mem-wall-active == 1)
(or	(up-compare-goal mem-stronghold-active == 1)
	(up-compare-goal mem-tower-def-active == 1)))
	(up-compare-goal mem-build-gate-vills g:< build-gate-vills-max)
=>
	(up-modify-goal mem-build-gate-vills c:+ 2))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-fortify-ready != 1)
(or	(up-compare-goal mem-wall-active == 1)
(or	(up-compare-goal mem-stronghold-active == 1)
(or	(up-compare-goal mem-tower-def-active == 1)
	(up-compare-goal mem-tower-off-active == 1))))
	(up-compare-goal mem-build-tower-vills g:< build-tower-vills-max)
=>
	(up-modify-goal mem-build-tower-vills c:+ 2))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-repair-vills < 2)
=>
	(set-goal mem-build-repair-vills 2))

(defrule
	(current-age >= feudal-age)
	(up-compare-goal mem-build-raid-vills < raid-builder-vills)
=>
	(up-modify-goal mem-build-raid-vills g:= raid-builder-vills))

; ======================== DEDICATED BUILD CORPS (GROUP 19) ========================
; Full refresh only when wall/gate/tower locks are off (buildguard/towerguard handle locked recruits)
(defrule
	(current-age >= feudal-age)
(or	(up-compare-goal mem-build-wall-gate-lock == 1)
	(up-compare-goal mem-build-tower-lock == 1))
	(up-group-size c: build-workers-group > 0)
=>
	(up-modify-group-flag 1 c: build-workers-group))

(defrule
	(current-age >= feudal-age)
	(up-group-size c: build-workers-group < mem-build-pool-size)
	(up-compare-goal villagercount >= eco-fortify-vills-min)
	(up-compare-goal mem-build-wall-gate-lock != 1)
	(up-compare-goal mem-build-tower-lock != 1)
=>
	(up-modify-group-flag 0 c: build-workers-group)
	(up-reset-group c: build-workers-group)
	(up-full-reset-search)
	(up-find-local c: villager g: mem-build-pool-size)
	(up-remove-objects search-local object-data-group-flag c:== raid-food-group)
	(up-remove-objects search-local object-data-group-flag c:== raid-patrol-group)
	(up-remove-objects search-local object-data-group-flag c:== raid-escort-group)
	(up-remove-objects search-local object-data-group-flag c:== raid-builder-group)
	(up-remove-objects search-local object-data-group-flag c:== explore-army-group)
	(up-create-group 0 0 c: build-workers-group)
	(up-modify-group-flag 1 c: build-workers-group))

; ======================== CORPS: REPAIR DAMAGED WALLS/GATES NEAR TC ========================
(defrule
	(current-age >= feudal-age)
	(up-group-size c: build-workers-group > 0)
	(building-type-count town-center >= 1)
=>
	(up-full-reset-search)
	(up-find-local c: town-center c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object saved-point-x)
	(up-set-target-point saved-point-x)
	(up-find-local c: wall-class c: 32)
	(up-find-local c: gate-class c: 16)
	(up-find-local c: tower-class c: 12)
	(up-filter-distance c: -1 c: stronghold-repair-radius)
	(up-remove-objects search-local object-data-hitpoints g:>= stronghold-wall-hp-full)
	(up-get-search-state local-total))

(defrule
	(current-age >= feudal-age)
	(up-group-size c: build-workers-group > 0)
	(up-compare-goal local-total > 0)
	(up-set-target-object search-local c: 0)
=>
	(up-get-object-data object-data-id temporary-goal)
	(up-set-group search-local c: build-workers-group)
	(up-full-reset-search)
	(up-add-object-by-id search-remote g: temporary-goal)
	(up-target-objects 0 action-default -1 -1))

; ======================== EXTRA BUILDERS ON PENDING WALLS ========================
(defrule
	(up-pending-objects c: palisade-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 8)
=>
	(up-assign-builders c: wall-class c: 8))

(defrule
	(up-pending-objects c: palisade-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 6)
	(up-compare-goal mem-build-wall-vills < 8)
=>
	(up-assign-builders c: wall-class c: 6))

(defrule
	(up-pending-objects c: palisade-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 4)
	(up-compare-goal mem-build-wall-vills < 6)
=>
	(up-assign-builders c: wall-class c: 4))

(defrule
	(up-pending-objects c: palisade-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 2)
	(up-compare-goal mem-build-wall-vills < 4)
=>
	(up-assign-builders c: wall-class c: 2))

(defrule
	(up-pending-objects c: stone-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 8)
=>
	(up-assign-builders c: wall-class c: 8))

(defrule
	(up-pending-objects c: stone-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 6)
	(up-compare-goal mem-build-wall-vills < 8)
=>
	(up-assign-builders c: wall-class c: 6))

(defrule
	(up-pending-objects c: stone-wall >= 1)
	(up-compare-goal mem-build-wall-vills >= 4)
	(up-compare-goal mem-build-wall-vills < 6)
=>
	(up-assign-builders c: wall-class c: 4))

