	(up-compare-goal mem-build-gate-vills >= 6)
=>
	(up-assign-builders c: stone-gate2 c: 6))

(defrule
	(up-pending-objects c: stone-gate3 >= 1)
	(up-compare-goal mem-build-gate-vills >= 6)
=>
	(up-assign-builders c: stone-gate3 c: 6))

