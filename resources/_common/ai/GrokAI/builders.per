; ======================== KEEP FORTIFY GOING UNDER RISING CAPS (threat only) ========================
(defrule
	(goal inseln no)
	(current-age >= feudal-age)
	(game-time < wall-time-max)
	(up-compare-goal mem-wall-phase == wall-phase-done)
	(up-compare-goal mem-wall-active != 1)
	(up-compare-goal mem-build-gate-now g:< mem-build-gate-cap)
(or	(wood-amount >= wall-segment-wood)
	(stone-amount >= fort-stone-min))
(or	(goal underattack yes)
	(up-compare-goal mem-aggression-score >= wall-trigger-aggression))
=>
	(set-goal mem-wall-active 1)
	(set-goal mem-wall-phase wall-phase-build)
	(set-goal mem-wall-site wall-site-outer1)
	(set-goal mem-wall-segments wall-choke-seg-gate)
	(set-goal mem-wall-stuck 0))

(defrule
	(goal inseln no)
	(current-age >= feudal-age)
	(game-time < wall-time-max)
	(up-compare-goal mem-wall-phase == wall-phase-done)
	(up-compare-goal mem-wall-active != 1)
	(up-compare-goal mem-build-wall-now g:< mem-build-wall-cap)
	(wood-amount >= wall-segment-wood)
(or	(goal underattack yes)
	(up-compare-goal mem-aggression-score >= wall-trigger-aggression))
=>
	(set-goal mem-wall-active 1)
	(set-goal mem-wall-phase wall-phase-build)
	(set-goal mem-wall-site wall-site-outer1)
	(set-goal mem-wall-segments wall-choke-seg-gate)
	(set-goal mem-wall-stuck 0))

; ======================== MORE TOWERS WHILE POOL GROWS (ratio gated) ========================
(defrule
	(goal inseln no)
	(current-age >= feudal-age)
	(game-time < tower-time-max)
	(up-compare-goal mem-build-pool-size >= build-pool-feudal)
	(building-type-count-total tower-class < fort-tower-cap)
	(up-compare-goal mem-tower-def-active != 1)
	(up-compare-goal villagercount >= eco-fortify-vills-min)
	(wood-amount >= tower-wood-min)
	(building-type-count-total tower-class g:< mem-build-tower-target)
	(up-compare-goal mem-build-structure-count g:>= tower-per-buildings)
=>
	(set-goal mem-tower-def-active 1)
	(set-goal mem-tower-def-slot 0)
	(set-goal mem-tower-stuck 0))