;==============================================================================
; GrokAI v2.0 - Build corps: walls, gates, attack towers (group 19)
; Exclusive villagers for walls, gates, towers, TCs, castles, maintain/rebuild.
;==============================================================================

; ======================== TRACK WALL/GATE TOTALS ========================
(defrule
	(true)
=>
	(up-full-reset-search)
	(up-find-local c: gate-class c: 48)
	(up-get-search-state local-total)
	(up-modify-goal mem-build-gate-now g:= local-total))

(defrule
	(true)
=>
	(up-full-reset-search)
	(up-find-local c: wall-class c: 120)
	(up-get-search-state local-total)
	(up-modify-goal mem-build-wall-now g:= local-total))

(defrule
	(true)
=>
	(up-full-reset-search)
	(up-find-local c: building-class c: 256)
	(up-get-search-state local-total)
	(up-modify-goal mem-build-structure-count g:= local-total)
	(up-modify-goal mem-build-structure-count g:- mem-build-wall-now)
	(up-modify-goal mem-build-structure-count g:- mem-build-gate-now))

; ======================== TOWER TARGET: 1 PER 10 STRUCTURES ========================
(defrule
	(up-compare-goal mem-build-structure-count >= 200)
=>
	(set-goal mem-build-tower-target 20))

(defrule
	(up-compare-goal mem-build-structure-count >= 190)
	(up-compare-goal mem-build-structure-count < 200)
=>
	(set-goal mem-build-tower-target 19))

(defrule
	(up-compare-goal mem-build-structure-count >= 180)
	(up-compare-goal mem-build-structure-count < 190)
=>
	(set-goal mem-build-tower-target 18))

(defrule
	(up-compare-goal mem-build-structure-count >= 170)
	(up-compare-goal mem-build-structure-count < 180)
=>
	(set-goal mem-build-tower-target 17))

(defrule
	(up-compare-goal mem-build-structure-count >= 160)
	(up-compare-goal mem-build-structure-count < 170)
=>
	(set-goal mem-build-tower-target 16))

(defrule
	(up-compare-goal mem-build-structure-count >= 150)
	(up-compare-goal mem-build-structure-count < 160)
=>
	(set-goal mem-build-tower-target 15))

(defrule
	(up-compare-goal mem-build-structure-count >= 140)
	(up-compare-goal mem-build-structure-count < 150)
=>
	(set-goal mem-build-tower-target 14))

(defrule
