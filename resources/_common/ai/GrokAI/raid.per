(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-wall)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(up-pending-objects c: stone-wall < 2)
	(up-can-build-line saved-point-x point3-x c: stone-wall)
=>
	(up-build-line saved-point-x point3-x c: stone-wall)
	(up-assign-builders c: wall-class g: mem-build-wall-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-wall)
=>
	(set-goal mem-raid-build-step raid-build-step-gate))

; ======================== GATE (OVER EXISTING WALL) ========================
(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= feudal-age)
	(current-age < castle-age)
	(wood-amount >= wall-segment-wood)
	(not (up-point-contains saved-point-x c: wall-class))
	(up-can-build-line 0 saved-point-x c: palisade-wall)
=>
	(up-build-line saved-point-x saved-point-x c: palisade-wall)
	(up-assign-builders c: wall-class g: mem-build-wall-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(not (up-point-contains saved-point-x c: wall-class))
	(up-can-build-line 0 saved-point-x c: stone-wall)
=>
	(up-build-line saved-point-x saved-point-x c: stone-wall)
	(up-assign-builders c: wall-class g: mem-build-wall-vills)
	(set-goal mem-raid-stuck 0))

(defrule
