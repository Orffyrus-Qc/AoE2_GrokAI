	(up-assign-builders c: palisade-gate-foundation1 g: mem-build-gate-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(up-pending-objects c: stone-gate1 < 1)
	(up-point-contains saved-point-x c: wall-class)
	(up-compare-goal mem-gate-stone-align == 0)
	(up-can-build-line 0 saved-point-x c: stone-gate1)
=>
	(up-build-line saved-point-x saved-point-x c: stone-gate1)
	(up-assign-builders c: stone-gate1 g: mem-build-gate-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(up-pending-objects c: stone-gate2 < 1)
	(up-point-contains saved-point-x c: wall-class)
	(up-compare-goal mem-gate-stone-align == 1)
	(up-can-build-line 0 saved-point-x c: stone-gate2)
=>
	(up-build-line saved-point-x saved-point-x c: stone-gate2)
	(up-assign-builders c: stone-gate2 g: mem-build-gate-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(up-pending-objects c: stone-gate3 < 1)
	(up-point-contains saved-point-x c: wall-class)
	(up-compare-goal mem-gate-stone-align == 2)
	(up-can-build-line 0 saved-point-x c: stone-gate3)
=>
	(up-build-line saved-point-x saved-point-x c: stone-gate3)
	(up-assign-builders c: stone-gate3 g: mem-build-gate-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(up-pending-objects c: stone-gate4 < 1)
	(up-point-contains saved-point-x c: wall-class)
	(up-compare-goal mem-gate-stone-align == 3)
	(up-can-build-line 0 saved-point-x c: stone-gate4)
=>
	(up-build-line saved-point-x saved-point-x c: stone-gate4)
	(up-assign-builders c: stone-gate4 g: mem-build-gate-vills)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-gate)
=>
	(set-goal mem-raid-build-step raid-build-step-done))

; ======================== REPAIR FORWARD BASE ========================
(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-has-site == 1)
	(up-group-size c: raid-builder-group > 0)
=>
	(up-full-reset-search)
	(up-set-target-point saved-point-x)
	(up-find-local c: wall-class c: 16)
	(up-find-local c: gate-class c: 8)
	(up-find-local c: tower-class c: 4)
	(up-filter-distance c: -1 c: raid-repair-radius)
	(up-remove-objects search-local object-data-hitpoints g:>= stronghold-wall-hp-full)
	(up-get-search-state local-total))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-has-site == 1)
	(up-group-size c: raid-builder-group > 0)
	(up-compare-goal local-total > 0)
	(up-set-target-object search-local c: 0)
=>
	(up-get-object-data object-data-id temporary-goal)
	(up-full-reset-search)
	(up-set-target-point saved-point-x)
	(up-filter-distance c: -1 c: raid-repair-radius)
	(up-find-local c: villager g: mem-build-repair-vills)
	(up-remove-objects search-local object-data-order == orderid-repair)
	(up-add-object-by-id search-remote g: temporary-goal)
	(up-target-objects 0 action-default -1 -1))

; ======================== REBUILD MISSING FORWARD WALL ========================
(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-has-site == 1)
	(up-compare-goal mem-raid-build == 0)
	(current-age >= feudal-age)
	(current-age < castle-age)
	(wood-amount >= wall-segment-wood)
	(not (up-point-contains saved-point-x c: wall-class))
	(up-can-build-line 0 saved-point-x c: palisade-wall)
=>
	(up-build-line saved-point-x saved-point-x c: palisade-wall)
	(up-assign-builders c: wall-class g: mem-build-wall-vills))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-has-site == 1)
	(up-compare-goal mem-raid-build == 0)
	(current-age >= castle-age)
	(stone-amount >= raid-stone-segment-min)
	(not (up-point-contains saved-point-x c: wall-class))
	(up-can-build-line 0 saved-point-x c: stone-wall)
=>
	(up-build-line saved-point-x saved-point-x c: stone-wall)
	(up-assign-builders c: wall-class g: mem-build-wall-vills))

; ======================== FORWARD BUILD DONE / RETRY ========================
(defrule
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step >= raid-build-step-done)
=>
	(set-goal mem-raid-build 0)
	(set-goal mem-raid-build-step 0)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-build == 1)
(or	(up-pending-objects c: watch-tower >= 1)
(or	(up-pending-objects c: castle >= 1)
(or	(up-pending-objects c: town-center >= 1)
(or	(up-pending-objects c: stone-wall >= 1)
	(up-pending-objects c: stone-gate1 >= 1)))))
=>
	(set-goal mem-raid-build 0)
	(set-goal mem-raid-build-step 0))

(defrule
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-stuck >= raid-build-stuck-max)
=>
	(set-goal mem-raid-build 0)
	(set-goal mem-raid-build-step 0)
	(set-goal mem-raid-stuck 0))

(defrule
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-stuck < raid-build-stuck-max)
(or	(up-point-contains saved-point-x c: tree-class)
	(up-point-contains saved-point-x c: building-class))
=>
	(up-modify-goal mem-raid-stuck c:+ 1)
	(up-lerp-tiles saved-point-x position-self-x c: 1))