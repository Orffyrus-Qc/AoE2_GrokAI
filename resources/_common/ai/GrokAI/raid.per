	(up-lerp-tiles point3-x enemy-x c: 4))

(defrule
	(up-compare-goal mem-raid-active == 1)
	(up-compare-goal mem-raid-build == 1)
	(up-compare-goal mem-raid-build-step == raid-build-step-wall)
	(current-age >= feudal-age)
	(current-age < castle-age)
	(wood-amount >= wall-segment-wood)
	(up-pending-objects c: palisade-wall < 2)
	(up-can-build-line saved-point-x point3-x c: palisade-wall)
=>
